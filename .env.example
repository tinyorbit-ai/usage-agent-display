# Copy to .env and fill in. The real .env is gitignored — NEVER commit it (ADR 0003).
# The same USAGE_BEARER_TOKEN must be set on the server and every daemon, and in the
# firmware's config.h (API_BEARER_TOKEN).

# --- shared secret (server + daemons) ---
USAGE_BEARER_TOKEN=replace-with-a-long-random-shared-secret

# --- server ---
PORT=8080
USAGE_DB_PATH=usage.db
# A machine with nothing newer than this many seconds is flagged stale on the panel.
USAGE_STALE_AFTER_SECONDS=120
# Timezone the server reckons "this month" / "today" in (IANA name). Defaults to the
# server's own zone. Pin it so machines in different zones roll up consistently.
USAGE_RECKONING_TZ=UTC
# Optional monthly budget in USD. Unset or 0 disables the budget line on the panel.
USAGE_BUDGET_USD=0

# --- daemon (per machine) ---
USAGE_SERVER_URL=http://192.168.1.50:8080
USAGE_MACHINE_ID=mbp-14          # unique per machine; omit to derive from hostname
USAGE_INTERVAL_SECONDS=30
USAGE_PROVIDER=claude-code
